# =============================================================================
# InDE Professional Tier — Configuration
# Innovation Development Environment v3.16.0 "Production Trust"
# =============================================================================
# Copy this file to .env and fill in the required values.
#
# Usage:
#   cp .env.template .env
#   # Edit .env with your values
#   docker compose -f docker-compose.production.yml up -d
# =============================================================================

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Your InDE license key (provided by InDEVerse)
# Format: INDE-PRO-XXXXXXXXXXXX-XXXX
INDEVERSE_LICENSE_KEY=

# Your Anthropic API key (from console.anthropic.com)
# This key is used for AI coaching sessions
ANTHROPIC_API_KEY=

# Admin email for first-run setup
# This email will be used to create the initial administrator account.
# The admin user can access the Diagnostics Panel at /diagnostics.
# Admin role is auto-assigned on registration or startup.
INDE_ADMIN_EMAIL=

# =============================================================================
# OPTIONAL CONFIGURATION (with sensible defaults)
# =============================================================================

# ── Deployment Tier ──────────────────────────────────────────────────────────
# Determines which services run locally vs externally
# - single: All services on one host (default)
# - enterprise: External MongoDB/Redis, local app services
# - federated: Enterprise + external IKF federation endpoint
# INDE_DEPLOYMENT_TIER=single

# ── Network Configuration ────────────────────────────────────────────────────

# Port for the InDE web interface
# Default: 8080
# INDE_PORT=8080

# Public URL for this InDE instance (required for enterprise/federated)
# Used for OAuth callbacks, webhooks, and federation
# INDE_PUBLIC_URL=https://inde.yourcompany.com

# ── Domain & HTTPS Configuration (v3.16) ────────────────────────────────────

# Domain name for this InDE instance (required for HTTPS and email links)
# Example: app.indeverse.com
# INDE_DOMAIN=app.indeverse.com

# Full base URL with protocol (derived from INDE_DOMAIN if not set)
# Example: https://app.indeverse.com
# INDE_BASE_URL=https://app.indeverse.com

# ── Storage Configuration ────────────────────────────────────────────────────

# MongoDB connection (for enterprise/federated with external MongoDB)
# Single-host uses local container; set this for MongoDB Atlas or cluster
# Example: mongodb+srv://user:pass@cluster.mongodb.net/inde
# MONGODB_URL=

# MongoDB data directory (only for single-host local container)
# Default: ./data/db
# INDE_DB_DATA_PATH=./data/db

# ── Redis Configuration ──────────────────────────────────────────────────────

# Redis connection (for enterprise/federated with external Redis)
# Single-host uses local container; set this for Redis Cloud or cluster
# Example: redis://user:pass@redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com:12345
# REDIS_URL=

# ── Logging Configuration ────────────────────────────────────────────────────

# Logging level: DEBUG, INFO, WARNING, ERROR
# Default: INFO
# INDE_LOG_LEVEL=INFO

# ── License Mode ─────────────────────────────────────────────────────────────

# License validation mode
# - simulation: Local validation for testing (default)
# - live: Contact license.indeverse.com for production
# Default: simulation
# INDE_LICENSE_MODE=simulation

# ── Federation Mode ──────────────────────────────────────────────────────────

# IKF Federation mode
# - simulation: Local federation for testing (default)
# - live: Participate in global InDE federation
# Default: simulation
# IKF_FEDERATION_MODE=simulation

# Federation Hub URL (for federated tier)
# Central hub for cross-organization pattern sharing
# IKF_HUB_URL=https://hub.indeverse.com

# Organization ID for federation (assigned by InDEVerse)
# IKF_ORG_ID=

# Federation API key (for authenticating with hub)
# IKF_FEDERATION_KEY=

# ── LLM Configuration ────────────────────────────────────────────────────────

# LLM Provider (anthropic is the only supported option currently)
# LLM_PROVIDER=anthropic

# Default Claude model for coaching
# DEFAULT_MODEL=claude-sonnet-4-20250514

# Rate limit (tokens per minute)
# RATE_LIMIT_TPM=100000

# ── Rate Limiting (v3.15) ───────────────────────────────────────────────────

# Per-user coaching rate limit (requests per 60-second sliding window)
# Default: 30
# INDE_COACHING_RATE_LIMIT=30

# Per-IP authentication rate limit (attempts per window)
# Default: 10
# INDE_AUTH_RATE_LIMIT=10

# Authentication rate limit window duration (seconds)
# Default: 300 (5 minutes)
# INDE_AUTH_RATE_LIMIT_WINDOW=300

# ── Security Configuration ───────────────────────────────────────────────────

# JWT secret for authentication (auto-generated if not set)
# For production, set a strong random secret
# JWT_SECRET=

# Internal service-to-service token (auto-generated if not set)
# SERVICE_TOKEN=

# ── Image Configuration ──────────────────────────────────────────────────────

# Docker registry for InDE images
# Default: registry.indeverse.com
# INDE_REGISTRY=registry.indeverse.com

# InDE version to deploy
# Default: 3.16.0
# INDE_VERSION=3.16.0
